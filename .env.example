# Wifymy Environment Variables

# ==========================================
# Authentication (Stack Auth)
# ==========================================
# Get these from your Stack Auth dashboard
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
STACK_SECRET_SERVER_KEY=your_stack_secret_server_key

# ==========================================
# Database (Cloudflare D1)
# ==========================================
# To connect your local development environment directly to the remote Cloudflare D1 database:
# 1. Go to your Cloudflare Dashboard -> Workers & Pages -> D1 -> wifymy-db
# 2. In the "REST API" section, you'll find your Database ID and Account ID.
# 3. Create an API Token with D1 Edit permissions.
# 
# Format: https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/d1/database/<DATABASE_ID>
DATABASE_URL=https://api.cloudflare.com/client/v4/accounts/your_account_id/d1/database/your_database_id
DATABASE_AUTH_TOKEN=your_cloudflare_api_token
